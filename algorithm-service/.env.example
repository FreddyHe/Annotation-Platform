# Environment variables
APP_NAME=Annotation Algorithm Service
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "*"]
CORS_ALLOW_CREDENTIALS=true

# Backend
BACKEND_URL=http://localhost:8080

# File paths
UPLOAD_BASE_PATH=/root/autodl-fs/uploads

# Model paths
DINO_MODEL_PATH=models/groundingdino_swint_ogc.pth
DINO_CONFIG_PATH=models/GroundingDINO_SwinT_OGC.py
YOLO_MODEL_PATH=models/yolov8n.pt
VLM_MODEL_PATH=models/Qwen-VL-Chat

# VLM settings
VLM_MODEL_NAME=Qwen/Qwen-VL-Chat
VLM_MAX_TOKENS=4096

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/algorithm-service.log
